{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurigaagents.github.io/market-intelligence-pulse/schemas/source.schema.json",
  "title": "Market Intelligence Source",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "publisher", "title", "url", "accessed_at", "source_type", "retrieval_method", "mutable", "reliability_tier"],
  "properties": {
    "id": {"type": "string", "pattern": "^S-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]+$"},
    "publisher": {"type": "string"},
    "title": {"type": "string"},
    "url": {"type": "string", "format": "uri"},
    "canonical_url": {"type": "string", "format": "uri"},
    "accessed_at": {"type": "string"},
    "published_at": {"type": "string"},
    "source_type": {"type": "string"},
    "retrieval_method": {"type": "string"},
    "mutable": {"type": "boolean"},
    "paywall": {"type": "boolean"},
    "reliability_tier": {"type": "string"},
    "archive": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stored": {"type": "boolean"},
        "reason": {"type": "string"}
      }
    }
  }
}
